{
  "name": "mobile-engineering-agents",
  "version": "1.0.0",
  "private": true,
  "description": "An AI-first engineering toolkit that turns coding agents into Senior/Staff mobile engineers.",
  "license": "MIT",
  "author": "Sok Pich",
  "homepage": "https://github.com/sokpichdev/mobile-engineering-agents",
  "repository": {
    "type": "git",
    "url": "https://github.com/sokpichdev/mobile-engineering-agents.git"
  },
  "scripts": {
    "lint": "npm run lint:md && npm run lint:links",
    "lint:md": "markdownlint-cli2 \"**/*.md\"",
    "lint:md:fix": "markdownlint-cli2 --fix \"**/*.md\"",
    "lint:links": "markdown-link-check --quiet --config .github/mlc_config.json $(find . -name '*.md' -not -path './node_modules/*')",
    "lint:commits": "commitlint --from origin/main --to HEAD --verbose",
    "commitlint": "commitlint --edit"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "markdown-link-check": "^3.12.2",
    "markdownlint-cli2": "^0.22.1"
  }
}
